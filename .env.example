# =============================================================================
# RAG Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
# =============================================================================

# --- Phase 1: Ingestion, Chunking & Hybrid Retrieval ---

# Required: OpenAI API key for text-embedding-3-small
OPENAI_API_KEY=

# Optional: Voyage AI API key (required if EMBEDDING_PROVIDER=voyage)
VOYAGE_API_KEY=

# Optional: Google Gemini API key (required if EMBEDDING_PROVIDER=gemini)
GEMINI_API_KEY=

# Optional: Cohere API key (required if EMBEDDING_PROVIDER=cohere)
COHERE_API_KEY=

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma

# Embedding model and provider
# EMBEDDING_PROVIDER options: sentence_transformers (default, no API key),
# openai, voyage, gemini, cohere
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=sentence_transformers

# Device for local sentence_transformers embeddings: auto | cpu | cuda | mps
# (ignored by API providers; "auto" lets the library auto-detect CUDA/MPS/CPU)
EMBEDDING_DEVICE=auto

# Vector store provider
VECTOR_STORE_PROVIDER=chroma

# Retrieval configuration
DENSE_TOP_K=10
SPARSE_TOP_K=10
RERANK_CANDIDATE_POOL=20
RERANK_TOP_N=5
DENSE_WEIGHT=0.7
SPARSE_WEIGHT=0.3

# Reranking (cross-encoder second pass — precision boost after RRF fusion)
RERANKING_ENABLED=true
RERANKER_PROVIDER=sentence_transformers
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_DEVICE=auto

# Deduplication threshold (cosine similarity — chunks above this are skipped)
DEDUP_THRESHOLD=0.95

# Chunking
# CHUNK_STRATEGY options: fixed_size (default), recursive_header, semantic
CHUNK_STRATEGY=fixed_size
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Distance percentile threshold for semantic splits (CHUNK_STRATEGY=semantic only)
SEMANTIC_BREAKPOINT_PERCENTILE=95.0

# --- Phase 2: Generation (uncomment when starting Phase 2) ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# ANTHROPIC_API_KEY=

# --- Phase 3: Tracing (uncomment when starting Phase 3) ---
# SQLITE_DB_PATH=./data/traces.db
# TRACE_OUTPUT_DIR=./data/traces/

# --- General ---
LOG_LEVEL=INFO
