# =============================================================================
# RAG Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
# =============================================================================

# --- Phase 1: Ingestion, Chunking & Hybrid Retrieval ---

# Required by default: all five LLM-judge providers (citation, answer
# completeness, root-cause, failure-category, evidence-chain) default to
# anthropic, so this is needed out of the box even before Phase 2 generation
# is wired in.
ANTHROPIC_API_KEY=

# Optional: only required if EMBEDDING_PROVIDER=openai, any *_JUDGE_PROVIDER=openai,
# or using GPT-4o for generation (default EMBEDDING_PROVIDER is sentence_transformers,
# no key needed)
OPENAI_API_KEY=

# Optional: Voyage AI API key (required if EMBEDDING_PROVIDER=voyage or RERANKER_PROVIDER=voyage)
VOYAGE_API_KEY=

# Optional: Google Gemini API key (required if EMBEDDING_PROVIDER=gemini)
GEMINI_API_KEY=

# Optional: Cohere API key (required if EMBEDDING_PROVIDER=cohere or RERANKER_PROVIDER=cohere)
COHERE_API_KEY=

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma

# Embedding model and provider
# EMBEDDING_PROVIDER options: sentence_transformers (default, no API key),
# openai, voyage, gemini, cohere
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=sentence_transformers

# Device for local sentence_transformers embeddings: auto | cpu | cuda | mps
# (ignored by API providers; "auto" lets the library auto-detect CUDA/MPS/CPU)
EMBEDDING_DEVICE=auto

# Vector store provider
VECTOR_STORE_PROVIDER=chroma

# Retrieval configuration
DENSE_TOP_K=10
SPARSE_TOP_K=10
RERANK_CANDIDATE_POOL=20
RERANK_TOP_N=5
DENSE_WEIGHT=0.7
SPARSE_WEIGHT=0.3

# Reranking (cross-encoder second pass — precision boost after RRF fusion)
RERANKING_ENABLED=true
RERANKER_PROVIDER=sentence_transformers
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_DEVICE=auto

# Deduplication threshold (cosine similarity — chunks above this are skipped)
DEDUP_THRESHOLD=0.95

# Chunking
# CHUNK_STRATEGY options: fixed_size (default), recursive_header, semantic
CHUNK_STRATEGY=fixed_size
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Distance percentile threshold for semantic splits (CHUNK_STRATEGY=semantic only)
SEMANTIC_BREAKPOINT_PERCENTILE=95.0

# --- Phase 2: Generation ---
# LLM_PROVIDER and LLM_MODEL are not yet real settings — no generation
# orchestrator exists yet to consume them (planned; see CLAUDE.md).
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# Citation verification (LLM-as-judge check of [N]-style citations)
CITATION_JUDGE_PROVIDER=anthropic
CITATION_JUDGE_MODEL=claude-sonnet-4-5
CITATION_JUDGE_TEMPERATURE=0.0

# Answer completeness judging (used by confidence scoring)
ANSWER_COMPLETENESS_JUDGE_PROVIDER=anthropic
ANSWER_COMPLETENESS_JUDGE_MODEL=claude-sonnet-4-5
ANSWER_COMPLETENESS_JUDGE_TEMPERATURE=0.0

# Confidence scoring (composite of retrieval confidence, citation coverage,
# and answer completeness)
CONFIDENCE_RETRIEVAL_WEIGHT=0.3333333333333333
CONFIDENCE_CITATION_WEIGHT=0.3333333333333333
CONFIDENCE_COMPLETENESS_WEIGHT=0.3333333333333333

# Below this retrieval confidence, return a structured "insufficient
# information" response instead of generating an answer
RETRIEVAL_CONFIDENCE_THRESHOLD=0.5

# --- Phase 3: Tracing ---
SQLITE_DB_PATH=./data/traces.db
TRACE_OUTPUT_DIR=./data/traces/

# --- Phase 5: Trace View (diff view) ---
# Directory for per-span human-entered "expected output" corrections
HUMAN_CORRECTIONS_DIR=./data/eval/corrections

# Data directories (ingestion)
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed

# --- Phase 4: Root-Cause Analysis, Failure Categorization & Evidence Chain Narrative ---

# Root-cause analysis (backward span-quality judging — LLM-as-judge scores
# each span's input→output transformation quality, 1-5, walking a failed
# trace backward)
ROOT_CAUSE_JUDGE_PROVIDER=anthropic
ROOT_CAUSE_JUDGE_MODEL=claude-sonnet-4-5
ROOT_CAUSE_JUDGE_TEMPERATURE=0.0
ROOT_CAUSE_QUALITY_THRESHOLD=2

# Failure categorization (classifies a root-cause span into the failure
# taxonomy — Retrieval Failure, Ranking Failure, Extraction Hallucination,
# Citation Error, Generation Incomplete, Context Loss, or Other)
FAILURE_CATEGORY_JUDGE_PROVIDER=anthropic
FAILURE_CATEGORY_JUDGE_MODEL=claude-sonnet-4-5
FAILURE_CATEGORY_JUDGE_TEMPERATURE=0.0

# Evidence chain narrative (LLM-as-judge synthesizes a causal narrative from
# the ordered evidence chain leading to a diagnosed root cause)
EVIDENCE_CHAIN_JUDGE_PROVIDER=anthropic
EVIDENCE_CHAIN_JUDGE_MODEL=claude-sonnet-4-5
EVIDENCE_CHAIN_JUDGE_TEMPERATURE=0.0

# --- General ---
LOG_LEVEL=INFO
